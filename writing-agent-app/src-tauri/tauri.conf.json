{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Writing Agent App",
  "version": "0.1.0",
  "identifier": "com.lanmeng.writingagentapp.preview0414",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "C:\\nvm4w\\nodejs\\npm.cmd run dev -- --host 0.0.0.0 --port 1420",
    "beforeBuildCommand": "C:\\nvm4w\\nodejs\\npm.cmd run build"
