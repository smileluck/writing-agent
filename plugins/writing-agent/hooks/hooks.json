{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/bootstrap_workspace.py\""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "humanizer|article-illustrator",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/auto_clean_hook.py\""
          }
        ]
      }
    ]
  }
}
